{
  "expo": {
    "name": "Question Call",
    "slug": "qustion-call",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": ["questioncall", "com.questioncall.app"],
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.questioncall.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "QuestionCall needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "QuestionCall needs microphone access for voice and video calls."
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_PHONE_CALL",
        "FOREGROUND_SERVICE_MEDIA_PROJECTION",
        "MANAGE_OWN_CALLS",
        "USE_FULL_SCREEN_INTENT"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.questioncall.app",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withCallKeep",
      "./plugins/withAsyncStorageRepo",
      "expo-router",
      "react-native-full-screen-notification-incoming-call",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#10B981",
          "androidMode": "default",
          "sounds": [
            "./assets/sounds/notification_sound.mp3",
            "./assets/sounds/incoming_ringtone.mp3",
            "./assets/sounds/outgoing_ringtone.mp3"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QuestionCall to access your photos for sending images.",
          "cameraPermission": "Allow QuestionCall to use your camera for taking photos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow QuestionCall to use Face ID for secure wallet access."
        }
      ],
      "expo-asset",
      [
        "@sentry/react-native",
        {
          "organization": "question-call",
          "project": "react-native"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/86d256ec-943f-49e8-adaf-659400e4edac"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86d256ec-943f-49e8-adaf-659400e4edac"
      }
    },
    "owner": "question-call"
  }
}
