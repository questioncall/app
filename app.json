{
  "expo": {
    "name": "QuestionCall",
    "slug": "qustion-call",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": ["questioncall", "com.siddthecoder.qustioncall"],
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.siddthecoder.qustioncall",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "QuestionCall needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "QuestionCall needs microphone access for voice and video calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_PHONE_CALL",
        "MANAGE_OWN_CALLS",
        "USE_FULL_SCREEN_INTENT"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.siddthecoder.qustioncall",
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withCallKeep",
      "expo-router",
      // ["@sentry/react-native/expo", { "uploadSourceMaps": false }],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#3B82F6",
          "androidMode": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow QuestionCall to access your photos for sending images.",
          "cameraPermission": "Allow QuestionCall to use your camera for taking photos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow QuestionCall to use Face ID for secure wallet access."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "86d256ec-943f-49e8-adaf-659400e4edac"
      }
    },
    "owner": "siddthecoder"
  }
}
